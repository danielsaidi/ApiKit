{"primaryContentSections":[{"kind":"content","content":[{"anchor":"Overview","level":2,"type":"heading","text":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Implementing API integrations with ApiKit is very easy. You can either fetch raw "},{"type":"codeVoice","code":"URLRequest"},{"type":"text","text":"s and handle the raw data, or create custom "},{"type":"reference","isActive":true,"identifier":"doc:\/\/ApiKit\/documentation\/ApiKit\/ApiEnvironment"},{"type":"text","text":" and "},{"type":"reference","isActive":true,"identifier":"doc:\/\/ApiKit\/documentation\/ApiKit\/ApiRoute"},{"type":"text","text":" types to model various APIs."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"For instance, this code defines  "},{"type":"reference","isActive":true,"identifier":"doc:\/\/ApiKit\/documentation\/ApiKit\/ApiEnvironment"},{"type":"text","text":" and "},{"type":"reference","isActive":true,"identifier":"doc:\/\/ApiKit\/documentation\/ApiKit\/ApiRoute"},{"type":"text","text":", where the environment defines how to send the API key as a query parameter, and the route defines how to fetch movies:"}]},{"type":"codeListing","syntax":null,"code":["struct TheMovieDb {","","    enum Environment: ApiEnvironment {","","        case production(apiKey: String)","","        public var url: String {","            switch self {","            case .production: return \"https:\/\/api.themoviedb.org\/3\"","            }","        }","","        public var headers: [String : String]? { nil }","","        public var queryParams: [String : String]? {","            switch self {","            case .production(let key): return [\"api_key\": key]","            }","        }","    }","","    enum Route: ApiRoute {","","        case movie(id: Int)","        ","        public var path: String {","            switch self {","            case .movie(let id): return \"movie\/\\(id)\"","            }","        }","","        public var queryParams: [String : String]? {","            switch self {","            case .movie: return nil","            }","        }","","        public var httpMethod: HttpMethod {","            switch self {","                case .movie: return .get","            }","        }","","        public var headers: [String : String]? { nil }","","        public var formParams: [String : String]? { nil }","","        public var postData: Data? { nil }","    }","","    struct Movie: Codable, Identifiable {","        public let id: Int","        public let title: String","    }","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"We can then use "},{"type":"codeVoice","code":"URLSession.shared"},{"type":"text","text":" (or any "},{"type":"reference","isActive":true,"identifier":"doc:\/\/ApiKit\/documentation\/ApiKit\/ApiClient"},{"type":"text","text":") to fetch and parse movies by ID:"}]},{"type":"codeListing","syntax":"swift","code":["let client = URLSession.shared","let environment = TheMovieDb.Environment.production(\"API_KEY\") ","let route = TheMovieDb.Route.movie(id: 123) ","let movie: TheMovieDb.Movie = try await client.fetchItem(at: route, in: environment)"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Future versions may improve this further to make it even easier."}]}]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"sections":[],"variants":[{"paths":["\/documentation\/apikit\/getting-started"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"url":"doc:\/\/ApiKit\/documentation\/ApiKit\/Getting-Started","interfaceLanguage":"swift"},"abstract":[{"type":"text","text":"ScrollKit is a SwiftUI library that adds powerful scrolling features to SwiftUI, such as offset tracking and sticky scroll header views."}],"kind":"article","metadata":{"roleHeading":"Article","title":"Getting Started","role":"article","modules":[{"name":"ApiKit"}]},"hierarchy":{"paths":[["doc:\/\/ApiKit\/documentation\/ApiKit"]]},"references":{"doc://ApiKit/documentation/ApiKit/ApiEnvironment":{"role":"symbol","title":"ApiEnvironment","fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"ApiEnvironment"}],"abstract":[{"type":"text","text":"This protocol can be implemented to define API environments."}],"identifier":"doc:\/\/ApiKit\/documentation\/ApiKit\/ApiEnvironment","kind":"symbol","type":"topic","navigatorTitle":[{"kind":"identifier","text":"ApiEnvironment"}],"url":"\/documentation\/apikit\/apienvironment"},"doc://ApiKit/documentation/ApiKit/ApiClient":{"role":"symbol","title":"ApiClient","fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"ApiClient"}],"abstract":[{"type":"text","text":"This protocol can be implemented by types that can make api"},{"type":"text","text":" "},{"type":"text","text":"requests and return the raw data."}],"identifier":"doc:\/\/ApiKit\/documentation\/ApiKit\/ApiClient","kind":"symbol","type":"topic","navigatorTitle":[{"kind":"identifier","text":"ApiClient"}],"url":"\/documentation\/apikit\/apiclient"},"doc://ApiKit/documentation/ApiKit/ApiRoute":{"role":"symbol","title":"ApiRoute","fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"ApiRoute"}],"abstract":[{"type":"text","text":"This protocol can be implemented to define API routes."}],"identifier":"doc:\/\/ApiKit\/documentation\/ApiKit\/ApiRoute","kind":"symbol","type":"topic","navigatorTitle":[{"kind":"identifier","text":"ApiRoute"}],"url":"\/documentation\/apikit\/apiroute"},"doc://ApiKit/documentation/ApiKit":{"role":"collection","title":"ApiKit","abstract":[{"type":"text","text":"ApiKit is a Swift library that makes it easy to integrate with REST-based web APIs over HTTP."}],"identifier":"doc:\/\/ApiKit\/documentation\/ApiKit","kind":"symbol","type":"topic","url":"\/documentation\/apikit"}}}